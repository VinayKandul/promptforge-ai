# PromptForge AI - Environment Configuration
# Copy this file to .env and update the values

# ---- SECURITY (MUST change in production) ----
JWT_SECRET=your-super-secret-jwt-key-change-this
ENCRYPTION_KEY=your-encryption-key-for-api-keys

# ---- DATABASE ----
# Default: SQLite in the backend directory
# For PostgreSQL: postgresql://user:password@localhost:5432/promptforge
DATABASE_URL=sqlite:///promptforge.db

# ---- CORS ----
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ---- RATE LIMITING ----
RATE_LIMIT=60/minute

# ---- OLLAMA (Local Models) ----
OLLAMA_BASE_URL=http://localhost:11434

# ---- NOTE ----
# AI model API keys (OpenAI, Claude, Gemini, etc.) are managed
# per-user in the dashboard Settings page. They are stored encrypted
# in the database and are NOT configured via environment variables.
